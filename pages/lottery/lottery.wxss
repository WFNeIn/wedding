/* 抽奖号码页面样式 */
.lottery-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f8ff 0%, #ffffff 100%);
  padding: 30rpx 30rpx 40rpx;
}

/* 页面头部 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.1);
}

.title-divider {
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(to right, transparent, #87CEEB, transparent);
  margin: 24rpx auto;
  border-radius: 3rpx;
  box-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.3);
}

.page-desc {
  font-size: 28rpx;
  color: #87CEEB;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 号码卡片 */
.number-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fcff 100%);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.15);
  border: 2rpx solid #e6f3ff;
  text-align: center;
}

.card-header {
  margin-bottom: 40rpx;
}

.card-title {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
}

.number-display {
  background: linear-gradient(135deg, #87CEEB 0%, #6BB6D9 100%);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(135, 206, 235, 0.35);
}

.number-text {
  font-size: 120rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.loading-state {
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.card-tips {
  padding: 20rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  border: 1rpx solid #ffe082;
}

.tips-text {
  font-size: 24rpx;
  color: #f57c00;
  line-height: 1.6;
}

/* 中奖卡片 */
.prize-card {
  background: linear-gradient(135deg, #fff8e1 0%, #fffbf0 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.2);
  border: 2rpx solid #ffd54f;
  animation: prize-glow 2s ease-in-out infinite;
}

@keyframes prize-glow {
  0%, 100% {
    box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.2);
  }
  50% {
    box-shadow: 0 12rpx 32rpx rgba(255, 193, 7, 0.4);
  }
}

.prize-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.prize-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.prize-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f57c00;
}

.prize-content {
  text-align: center;
}

.prize-level {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #e65100;
  margin-bottom: 16rpx;
}

.prize-desc {
  display: block;
  font-size: 26rpx;
  color: #f57c00;
  line-height: 1.6;
}

/* 未中奖卡片 */
.no-prize-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  border: 2rpx solid #f0f8ff;
  text-align: center;
}

.no-prize-text {
  font-size: 28rpx;
  color: #999;
}

/* 说明卡片 */
.info-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  border: 2rpx solid #f0f8ff;
}

.info-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.info-content {
  display: flex;
  flex-direction: column;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2.2;
  padding-left: 20rpx;
  position: relative;
}

.info-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #87CEEB;
  border-radius: 50%;
}
