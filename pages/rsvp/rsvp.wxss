/* 回执页样式 */
.rsvp-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f8ff 0%, #ffffff 100%);
  padding: 30rpx 30rpx 40rpx;
}

/* 页面头部 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.1);
}

.title-divider {
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(to right, transparent, #87CEEB, transparent);
  margin: 24rpx auto;
  border-radius: 3rpx;
  box-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.3);
}

.page-desc {
  font-size: 28rpx;
  color: #87CEEB;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 表单卡片 */
.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  border: 2rpx solid #f0f8ff;
  margin-bottom: 30rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.optional {
  color: #999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input:focus {
  background: #f0f8ff;
  border: 2rpx solid #87CEEB;
}

/* 选择器 */
.form-picker {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  position: relative;
}

.picker-value {
  height: 88rpx;
  padding: 0 60rpx 0 24rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.form-picker::after {
  content: '›';
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%) rotate(90deg);
  font-size: 40rpx;
  color: #999;
  pointer-events: none;
}

/* 开关项 */
.form-item-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.form-item-switch .form-label {
  margin-bottom: 0;
}

.form-switch {
  transform: scale(0.9);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-textarea:focus {
  background: #f0f8ff;
  border: 2rpx solid #87CEEB;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #6BB6D9 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 60rpx;
  box-shadow: 0 8rpx 16rpx rgba(135, 206, 235, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 温馨提示卡片 */
.tips-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  border: 2rpx solid #f0f8ff;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.tips-title::before {
  content: '💡';
  margin-right: 12rpx;
  font-size: 32rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 8rpx;
  padding-left: 20rpx;
  position: relative;
}

.tips-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #87CEEB;
  font-weight: bold;
}

.tips-item:last-child {
  margin-bottom: 0;
}

/* 隐藏的小彩蛋 */
.easter-egg {
  text-align: center;
  padding: 60rpx 30rpx 40rpx;
  opacity: 0.15;
  transition: opacity 0.3s ease;
}

.easter-egg:active {
  opacity: 0.4;
}

.easter-egg-text {
  font-size: 20rpx;
  color: #ccc;
  letter-spacing: 1rpx;
  font-style: italic;
}
