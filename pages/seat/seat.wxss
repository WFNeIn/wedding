/* pages/seat/seat.wxss */
.seat-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #e6f7ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
}

/* 我的座位信息 */
.my-seat-info {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.2);
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #87CEEB;
  margin-bottom: 15rpx;
}

.info-content {
  font-size: 28rpx;
  color: #333;
}

.guest-type-tag {
  display: inline-block;
  background: #87CEEB;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-left: 10rpx;
}

/* 宾客类型选择器 */
.guest-type-selector {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.2);
}

.selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.type-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.type-item.selected {
  border-color: #87CEEB;
  background: #f0f8ff;
  transform: scale(1.02);
}

.type-color {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.type-item text {
  font-size: 28rpx;
  color: #333;
}

/* 缩放提示 */
.zoom-hint {
  background: #fff3cd;
  color: #856404;
  padding: 15rpx 20rpx;
  margin: 0 20rpx 15rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  text-align: center;
  border: 1rpx solid #ffeaa7;
}

/* 可滚动容器 */
.scroll-container {
  flex: 1;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.2);
}

/* 可缩放内容 */
.zoomable-content {
  min-width: 100%;
  min-height: 100%;
  transition: transform 0.1s ease-out;
}

/* 座位布局 */
.layout-container {
  padding: 30rpx 20rpx;
  min-width: 1600rpx;
}

/* 舞台 */
.stage {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  text-align: center;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 座位区域 */
.seats-area {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.seats-side {
  flex: 1;
}

.side-label {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: bold;
}

/* 区域分组 */
.area-section {
  margin-bottom: 30rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.classmate-area {
  border: 2rpx solid #FF6B6B;
}

.bride-area {
  border: 2rpx solid #FFB6C1;
}

.groom-area {
  border: 2rpx solid #87CEEB;
}

.area-label {
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  padding: 8rpx;
  background: white;
  border-radius: 8rpx;
}

/* 左侧3列布局 */
.left-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

/* 右侧2列布局 */
.right-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.table-group {
  background: white;
  border-radius: 12rpx;
  padding: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.table-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  text-align: center;
  font-weight: bold;
}

/* 圆桌容器 */
.round-table-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
}

/* 圆桌 */
.round-table {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
  border: 3rpx solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

.round-table.reserve-table {
  background: linear-gradient(135deg, #e0e0e0 0%, #c0c0c0 100%);
  border-color: #a0a0a0;
}

.table-number {
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
}

/* 座位围绕圆桌 - 使用绝对定位 */
.seat-item {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
  font-size: 20rpx;
  z-index: 2;
}

/* 10个座位均匀分布在圆周上 - 使用三角函数计算位置 */
/* 圆心在100rpx,100rpx，半径82rpx，座位半径18rpx */

/* 座位1: 0度 (顶部) */
.seat-position-1 {
  top: 18rpx;
  left: 82rpx;
}

/* 座位2: 36度 */
.seat-position-2 {
  top: 30rpx;
  left: 131rpx;
}

/* 座位3: 72度 */
.seat-position-3 {
  top: 64rpx;
  left: 160rpx;
}

/* 座位4: 108度 */
.seat-position-4 {
  top: 108rpx;
  left: 160rpx;
}

/* 座位5: 144度 */
.seat-position-5 {
  top: 142rpx;
  left: 131rpx;
}

/* 座位6: 180度 (底部) */
.seat-position-6 {
  top: 154rpx;
  left: 82rpx;
}

/* 座位7: 216度 */
.seat-position-7 {
  top: 142rpx;
  left: 33rpx;
}

/* 座位8: 252度 */
.seat-position-8 {
  top: 108rpx;
  left: 4rpx;
}

/* 座位9: 288度 */
.seat-position-9 {
  top: 64rpx;
  left: 4rpx;
}

/* 座位10: 324度 */
.seat-position-10 {
  top: 30rpx;
  left: 33rpx;
}

.seat-item.available {
  cursor: pointer;
}

.seat-item.available:active {
  transform: scale(0.9);
}

.seat-item.occupied {
  opacity: 0.8 !important;
  border-width: 2rpx;
}

.seat-item.reserved {
  opacity: 0.4 !important;
  cursor: not-allowed;
}

.seat-item.selected {
  border: 3rpx solid #FF4500 !important;
  box-shadow: 0 0 0 2rpx rgba(255, 69, 0, 0.3);
  transform: scale(1.15);
  opacity: 1 !important;
}

.seat-label {
  font-size: 18rpx;
  color: #333;
  font-weight: bold;
}

/* 通道 */
.aisle {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.aisle text {
  writing-mode: vertical-rl;
  font-size: 28rpx;
  color: #999;
  letter-spacing: 10rpx;
}

/* 提交按钮 */
.submit-container {
  margin: 0 20rpx 20rpx;
  padding: 0 20rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(135, 206, 235, 0.4);
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}
