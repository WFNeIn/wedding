/* pages/seat/seat.wxss */
.seat-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f5f7fa 0%, #ffffff 100%);
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 婚宴厅布局容器 */
.hall-layout-wrapper {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  overflow: visible;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.hall-layout {
  width: 100%;
  transition: transform 0.3s ease;
  touch-action: none;
}

/* 婚宴厅整体布局 */
.hall-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
}

/* T字型舞台 - 完整元素，绝对定位 */
.stage-container {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stage-horizontal {
  width: 260rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #E8E8E8 0%, #D0D0D0 100%);
  border-radius: 12rpx 12rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  border-bottom: none;
}

.stage-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #888;
  letter-spacing: 4rpx;
}

.stage-vertical {
  width: 60rpx;
  height: 320rpx;
  background: linear-gradient(180deg, #E8E8E8 0%, #D0D0D0 100%);
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  border-top: none;
  position: relative;
}

.stage-vertical::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: calc(100% - 40rpx);
  border-left: 2rpx dashed rgba(0, 0, 0, 0.15);
  border-right: 2rpx dashed rgba(0, 0, 0, 0.15);
}

/* 入口 - 浮动在右侧中间 */
.entrance-gate {
  position: absolute;
  right: -40rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entrance-text {
  font-size: 18rpx;
  color: #888;
  writing-mode: vertical-lr;
  letter-spacing: 4rpx;
  padding: 12rpx 8rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 每一行 */
.hall-row {
  display: flex;
  gap: 10rpx;
  justify-content: center;
}

/* 方格单元 */
.grid-cell {
  flex: 0 0 110rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空格 */
.grid-cell.empty {
  background: transparent;
}

/* 舞台顶部 - 合并为一个整体 */
.grid-cell.stage-top {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 6rpx 20rpx rgba(245, 87, 108, 0.4);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
}

.grid-cell.stage-left {
  border-radius: 12rpx 0 0 0;
  border-right: none;
}

.grid-cell.stage-middle {
  border-radius: 0;
  border-left: none;
  border-right: none;
}

.grid-cell.stage-right {
  border-radius: 0 12rpx 0 0;
  border-left: none;
}

.stage-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 舞台T台 - 与顶部连接 */
.grid-cell.stage-runway {
  background: linear-gradient(180deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.3);
  position: relative;
  border-left: 3rpx solid rgba(255, 255, 255, 0.3);
  border-right: 3rpx solid rgba(255, 255, 255, 0.3);
}

/* 最后一个T台格子添加底部圆角 */
.grid-cell.stage-runway-last {
  border-radius: 0 0 30rpx 30rpx;
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.3);
}

.grid-cell.stage-runway::after {
  content: '';
  position: absolute;
  top: 15rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: calc(100% - 30rpx);
  border-left: 2rpx dashed rgba(255, 255, 255, 0.4);
  border-right: 2rpx dashed rgba(255, 255, 255, 0.4);
}

/* 桌子单元格 */
.grid-cell.table-cell {
  background: transparent;
}

/* 桌子样式 */
.table-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  transition: all 0.3s ease;
}

.table-cell:active .table-item {
  transform: scale(0.95);
}

.table-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.table-circle::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.5);
  border-radius: 50%;
}

.table-number {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  z-index: 1;
}

.table-label {
  font-size: 16rpx;
  color: #666;
  text-align: center;
}

/* 不同宾客类型的颜色 - 暖色调高区分度 */
.bride-family .table-circle {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
}

.father-friends .table-circle {
  background: linear-gradient(135deg, #FFA07A 0%, #FF7F50 100%);
}

.classmate .table-circle {
  background: linear-gradient(135deg, #FFD93D 0%, #F39C12 100%);
}

.mother-friends .table-circle {
  background: linear-gradient(135deg, #FF6348 0%, #E74C3C 100%);
}

.relatives .table-circle {
  background: linear-gradient(135deg, #FDCB6E 0%, #E17055 100%);
}

/* 图例卡片 */
.legend-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.legend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.legend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.legend-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.legend-dot.bride-family {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
}

.legend-dot.father-friends {
  background: linear-gradient(135deg, #FFA07A 0%, #FF7F50 100%);
}

.legend-dot.classmate {
  background: linear-gradient(135deg, #FFD93D 0%, #F39C12 100%);
}

.legend-dot.mother-friends {
  background: linear-gradient(135deg, #FF6348 0%, #E74C3C 100%);
}

.legend-dot.relatives {
  background: linear-gradient(135deg, #FDCB6E 0%, #E17055 100%);
}
