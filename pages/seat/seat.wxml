<!--pages/seat/seat.wxml-->
<view class="seat-container">
  <!-- 可缩放的婚宴厅布局 -->
  <view class="hall-layout-wrapper">
    <view class="hall-layout">
      
      <!-- 婚宴厅布局 - 5列6行方格 -->
      <view class="hall-content">
        <!-- T字型舞台 - 完整元素 -->
        <view class="stage-container">
          <view class="stage-horizontal">
            <text class="stage-text">🎭 舞台 🎭</text>
          </view>
          <view class="stage-vertical"></view>
        </view>

        <!-- 入口 - 浮动在右侧中间 -->
        <view class="entrance-gate">
          <text class="entrance-text">🚪 入口</text>
        </view>

        <!-- 第1行：空 + 空 + 空 + 空 + 空 -->
        <view class="hall-row">
          <view class="grid-cell empty"></view>
          <view class="grid-cell empty"></view>
          <view class="grid-cell empty"></view>
          <view class="grid-cell empty"></view>
          <view class="grid-cell empty"></view>
        </view>

        <!-- 第2行：桌1 + 桌2 + 空 + 桌3 + 桌4 -->
