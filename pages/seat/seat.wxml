          <view class="grid-cell table-cell">
            <view class="table-item {{allTables[0].guestType}}">
              <view class="table-circle">
                <text class="table-number">{{allTables[0].tableNum}}</text>
              </view>
              <view class="table-label">{{allTables[0].guestTypeName}}</view>
            </view>
          </view>
