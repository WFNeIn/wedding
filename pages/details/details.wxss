/* 详情页样式 - 与首页风格一致 */
.details-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f8ff 0%, #ffffff 100%);
  padding: 30rpx 30rpx 40rpx;
  position: relative;
}

/* 背景音乐控制按钮 */
.music-control {
  position: fixed;
  top: 120rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.4);
  z-index: 100;
  transition: all 0.3s ease;
}

.music-control:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.5);
}

.music-icon {
  font-size: 48rpx;
  animation: musicPause 0.5s ease forwards;
}

.music-control.playing .music-icon {
  animation: musicRotate 3s linear infinite;
}

@keyframes musicRotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes musicPause {
  to {
    transform: rotate(0deg);
  }
}

/* 播放时的脉冲效果 */
.music-control.playing::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  border-radius: 50%;
  border: 2rpx solid #87CEEB;
  animation: musicPulse 2s ease-out infinite;
}

@keyframes musicPulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.3);
    opacity: 0;
  }
}

/* 页面头部 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 2rpx;
}

.title-divider {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(to right, transparent, #87CEEB, transparent);
  margin: 20rpx auto 0;
}

/* 区块卡片 */
.section-card {
  margin-bottom: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  border: 2rpx solid #f0f8ff;
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 婚礼流程 - 时间轴样式 */
.timeline-container {
  padding: 20rpx 0 20rpx 20rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  margin-bottom: 50rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

/* 时间轴左侧 */
.timeline-left {
  width: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex-shrink: 0;
}

.timeline-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
  position: relative;
  z-index: 2;
}

.timeline-dot.first {
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.4);
  animation: pulse-blue 2s ease-in-out infinite;
}

.timeline-dot.last {
  background: linear-gradient(135deg, #B0E0E6 0%, #D4E8F0 100%);
  box-shadow: 0 4rpx 12rpx rgba(176, 224, 230, 0.4);
}

@keyframes pulse-blue {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.4);
  }
  50% {
    transform: scale(1.1);
    box-shadow: 0 6rpx 20rpx rgba(135, 206, 235, 0.6);
  }
}

.dot-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ffffff;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: linear-gradient(to bottom, #87CEEB 0%, #E0F4FF 100%);
  margin-top: 8rpx;
  position: relative;
}

/* 时间轴右侧内容 */
.timeline-right {
  flex: 1;
  padding-left: 30rpx;
}

.timeline-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fcff 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.08);
  border: 2rpx solid #f0f8ff;
  position: relative;
  transition: all 0.3s ease;
}

.timeline-card.highlight {
  background: linear-gradient(135deg, #f0f8ff 0%, #e6f3ff 100%);
  border: 2rpx solid #87CEEB;
  box-shadow: 0 6rpx 20rpx rgba(135, 206, 235, 0.15);
}

.timeline-card::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 30rpx;
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 12rpx solid #f0f8ff;
}

.timeline-card.highlight::before {
  border-right-color: #87CEEB;
}

.timeline-header-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.timeline-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.timeline-time {
  font-size: 36rpx;
  font-weight: 700;
  color: #87CEEB;
  letter-spacing: 2rpx;
}

.timeline-card.highlight .timeline-time {
  color: #5AADCE;
}

.timeline-event {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.timeline-badge {
  display: inline-block;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-top: 16rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}

/* 旧样式保留（兼容） */
.schedule-list {
  padding: 20rpx 0;
}

.schedule-item {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  position: relative;
}

.schedule-item:last-child {
  margin-bottom: 0;
}

.schedule-time-box {
  width: 140rpx;
  flex-shrink: 0;
}

.schedule-time {
  font-size: 32rpx;
  font-weight: 600;
  color: #87CEEB;
}

.schedule-line {
  width: 60rpx;
  height: 2rpx;
  background: #87CEEB;
  margin: 0 20rpx;
  position: relative;
}

.schedule-line::before {
  content: '';
  position: absolute;
  left: -6rpx;
  top: -4rpx;
  width: 10rpx;
  height: 10rpx;
  background: #87CEEB;
  border-radius: 50%;
}

.schedule-event-box {
  flex: 1;
}

.schedule-event {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 地点信息卡片 */
.venue-card {
  background: linear-gradient(135deg, #f0f8ff 0%, #ffffff 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e6f3ff;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.08);
}

.venue-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.venue-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}

.venue-content {
  flex: 1;
}

.venue-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.venue-tag {
  display: inline-block;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.venue-address-box {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.address-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.venue-address {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

/* 联系人卡片 */
.contact-card {
  background: linear-gradient(135deg, #f0f8ff 0%, #ffffff 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e6f3ff;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.08);
}

.contact-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}

.contact-content {
  flex: 1;
}

.contact-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.contact-role {
  display: inline-block;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.contact-phone-box {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.phone-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.contact-phone {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 统一的操作按钮样式 */
.action-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #f8fcff 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid #e6f3ff;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(135, 206, 235, 0.1), transparent);
  transition: left 0.5s ease;
}

.action-btn:active::before {
  left: 100%;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.15);
}

.map-btn {
  border-color: #d4edff;
}

.call-btn {
  border-color: #d4edff;
  background: linear-gradient(135deg, #ffffff 0%, #f8fcff 100%);
}

.btn-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}

.call-btn .btn-icon {
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.3);
}

.btn-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.btn-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.btn-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.btn-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 56rpx;
  color: #87CEEB;
  font-weight: 300;
  line-height: 1;
}

.call-btn .arrow-icon {
  color: #87CEEB;
}

/* 旧样式保留（兼容） */
.venue-info {
  margin-bottom: 30rpx;
}

.map-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f0f8ff 0%, #e6f7ff 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.map-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.map-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.map-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.map-desc {
  font-size: 24rpx;
  color: #999;
}

.map-arrow {
  font-size: 48rpx;
  color: #87CEEB;
  font-weight: 300;
}

.contact-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

/* 温馨提示 */
.tips-box {
  text-align: center;
  padding: 30rpx 20rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}
