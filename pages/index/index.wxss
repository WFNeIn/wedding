/* 抽奖入口卡片 */
.lottery-card {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.3);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.lottery-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  animation: shine 3s ease-in-out infinite;
}

@keyframes shine {
  0%, 100% {
    transform: translate(0, 0);
    opacity: 0;
  }
  50% {
    transform: translate(-30%, -30%);
    opacity: 1;
  }
}

.lottery-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.4);
}

.lottery-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.lottery-icon {
  font-size: 50rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.lottery-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lottery-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.lottery-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.lottery-arrow {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

/* 温馨提示卡片 */
.tips-card {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.2);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-align: center;
}

.tips-content {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.8;
  text-align: center;
  opacity: 0.95;
}


/* ==================== 主题切换功能 ==================== */

/* 主题切换按钮 */
.theme-switch-btn {
  position: fixed !important;
  top: 100rpx !important;
  right: 30rpx !important;
  width: 70rpx;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  z-index: 999999 !important;
  transition: all 0.3s ease;
  cursor: pointer;
  opacity: 1 !important;
  visibility: visible !important;
  backdrop-filter: blur(10rpx);
}

.theme-switch-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.theme-icon {
  font-size: 36rpx;
  line-height: 1;
}

.theme-icon {
  font-size: 40rpx;
}

/* 主题选择器弹窗 */
.theme-selector-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.theme-selector-content {
  width: 90%;
  max-width: 700rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  animation: slideUp 0.3s ease;
}

.theme-selector-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.theme-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.theme-option:active {
  transform: scale(0.95);
}

.theme-option.active {
  border-color: #d4af37;
  background: linear-gradient(135deg, #fffef9 0%, #fefcf3 100%);
}

.theme-preview {
  width: 120rpx;
  height: 160rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.preview-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.preview-seal {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 方案1：玫瑰金 */
.theme1-preview .preview-bg {
  background: linear-gradient(135deg, #8B4789 0%, #C76B98 50%, #E8A0BF 100%);
}

.theme1-preview .preview-seal {
  background: linear-gradient(135deg, #E8A0BF 0%, #F4C2C2 50%, #E8A0BF 100%);
}

/* 方案2：翡翠绿 */
.theme2-preview .preview-bg {
  background: linear-gradient(135deg, #0F4C3A 0%, #1B7A5E 50%, #2D9B81 100%);
}

.theme2-preview .preview-seal {
  background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
}

/* 方案3：宝石蓝 */
.theme3-preview .preview-bg {
  background: linear-gradient(135deg, #1B3A6D 0%, #2E5090 50%, #4169B3 100%);
}

.theme3-preview .preview-seal {
  background: linear-gradient(135deg, #C0C0C0 0%, #E8E8E8 50%, #C0C0C0 100%);
}

/* 方案4：中国红 */
.theme4-preview .preview-bg {
  background: linear-gradient(135deg, #8B0000 0%, #B22222 30%, #DC143C 60%, #C41E3A 100%);
}

.theme4-preview .preview-seal {
  background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
}

/* 方案5：樱花粉 */
.theme5-preview .preview-bg {
  background: linear-gradient(135deg, #9B4F96 0%, #C76B98 50%, #FFB6C1 100%);
}

.theme5-preview .preview-seal {
  background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
}

.theme-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.theme-desc {
  font-size: 22rpx;
  color: #999;
}

/* ==================== 主题样式变量 ==================== */

/* 方案1：玫瑰金 + 香槟色 */
.opening-animation.theme1 {
  background: linear-gradient(135deg, #8B4789 0%, #C76B98 50%, #E8A0BF 100%);
}

.opening-animation.theme1 .seal-border {
