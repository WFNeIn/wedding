/* 首页样式 */
.index-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f8ff 0%, #ffffff 100%);
  padding-bottom: 40rpx;
  position: relative;
}

/* 首页内容初始隐藏 */
.index-container > view:not(.opening-animation) {
  opacity: 0;
}

/* 开场动画遮罩 */
.opening-animation {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: linear-gradient(135deg, #f0f8ff 0%, #e6f3ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeOut 0.8s ease 2.7s forwards;
}

@keyframes fadeOut {
  to {
    opacity: 0;
    visibility: hidden;
  }
}

/* 请柬封面容器 */
.invitation-cover {
  width: 600rpx;
  height: 800rpx;
  position: relative;
  perspective: 2000rpx;
}

/* 左侧封面 */
.cover-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 24rpx 0 0 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  transform-origin: left center;
  transition: transform 1s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  z-index: 2;
}

.invitation-cover.opening .cover-left {
  transform: rotateY(-160deg);
}

/* 右侧封面 */
.cover-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-radius: 0 24rpx 24rpx 0;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: right center;
  transition: transform 1s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  z-index: 2;
}

.invitation-cover.opening .cover-right {
  transform: rotateY(160deg);
}

/* 封面内容 */
.cover-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 60rpx 40rpx;
  color: #ffffff;
}

.cover-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  margin-bottom: 40rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.cover-divider {
  width: 120rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.8);
  margin-bottom: 40rpx;
  border-radius: 2rpx;
}

.cover-names {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.cover-date {
  font-size: 28rpx;
  letter-spacing: 2rpx;
  opacity: 0.95;
}

/* 封面装饰 */
.cover-decoration {
  animation: float 3s ease-in-out infinite;
}

.decoration-icon {
  font-size: 120rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.2));
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

/* 淡入内容 */
.fade-in-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  opacity: 0;
  transition: opacity 0.8s ease;
  z-index: 3;
}

.fade-in-content.show {
  opacity: 1;
}

.welcome-text {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #87CEEB;
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
  text-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.3);
  animation: slideUp 0.8s ease;
}

.welcome-subtitle {
  display: block;
  font-size: 32rpx;
  color: #666;
  letter-spacing: 4rpx;
  animation: slideUp 0.8s ease 0.2s both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 页面内容淡入动画 */
.fade-in-page {
  animation: pageSlideIn 1s ease forwards !important;
}

@keyframes pageSlideIn {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 为不同元素添加延迟,创造层次感 */
.swiper-container.fade-in-page {
  animation-delay: 0s;
}

.info-card.fade-in-page {
  animation-delay: 0.2s;
}

.lottery-card.fade-in-page {
  animation-delay: 0.4s;
}

.tips-card.fade-in-page {
  animation-delay: 0.6s;
}

/* 轮播图容器 */
.swiper-container {
  width: 100%;
  height: 750rpx;
  position: relative;
  overflow: hidden;
}

.photo-swiper {
  width: 100%;
  height: 100%;
}

.photo-image {
  width: 100%;
  height: 100%;
}

/* 婚礼信息卡片 */
.info-card {
  margin: -80rpx 30rpx 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.15);
  position: relative;
  z-index: 10;
}

/* 新人名字 */
.couple-names {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.couple-names .name {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 4rpx;
}

.couple-names .separator {
  font-size: 40rpx;
  color: #87CEEB;
  margin: 0 20rpx;
  font-weight: 300;
}

/* 分隔线 */
.divider {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(to right, transparent, #87CEEB, transparent);
  margin: 0 auto 40rpx;
}

/* 信息详情卡片 */
.info-detail-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f8fcff 0%, #ffffff 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e6f3ff;
  box-shadow: 0 4rpx 16rpx rgba(135, 206, 235, 0.08);
  transition: all 0.3s ease;
}

.info-detail-card:last-of-type {
  margin-bottom: 0;
}

.info-detail-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.12);
}

.detail-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.2);
}

.date-icon {
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
}

.venue-icon {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
}

.address-icon {
  background: linear-gradient(135deg, #98D8C8 0%, #B2E5D4 100%);
}

.detail-icon {
  font-size: 40rpx;
}

.detail-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.detail-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

.detail-value.address {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  line-height: 1.6;
}

.detail-hint {
  font-size: 22rpx;
  color: #87CEEB;
  margin-top: 4rpx;
  opacity: 0.8;
}

.detail-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.detail-arrow .arrow-icon {
  font-size: 36rpx;
  color: #87CEEB;
  font-weight: 700;
  line-height: 1;
}

/* 旧样式保留（兼容） */
.info-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.info-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.6;
}

.info-value.address {
  font-size: 28rpx;
  color: #666;
}

/* 倒计时容器 */
.countdown-container {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.countdown-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.countdown-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 倒计时时间盒子 */
.countdown-time-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.time-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #f0f8ff 0%, #e6f3ff 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(135, 206, 235, 0.1);
}

.time-item.special {
  background: linear-gradient(135deg, #ffe6e6 0%, #fff0f0 100%);
  animation: pulse 1.5s ease-in-out infinite;
}

.time-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #87CEEB;
  line-height: 1;
  margin-bottom: 8rpx;
}

.time-item.special .time-number {
  color: #FF6B6B;
}

.time-unit {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.time-item.special .time-unit {
  color: #FF6B6B;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 旧样式保留（兼容） */
.countdown-number-box {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.countdown-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #87CEEB;
  line-height: 1;
}

.countdown-number.special {
  color: #FF6B6B;
  animation: pulse 1.5s ease-in-out infinite;
}

.countdown-unit {
  font-size: 32rpx;
  color: #87CEEB;
  margin-left: 10rpx;
  font-weight: 500;
}

/* 抽奖入口卡片 */
.lottery-card {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.3);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.lottery-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  animation: shine 3s ease-in-out infinite;
}

@keyframes shine {
  0%, 100% {
    transform: translate(0, 0);
    opacity: 0;
  }
  50% {
    transform: translate(-30%, -30%);
    opacity: 1;
  }
}

.lottery-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.4);
}

.lottery-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.lottery-icon {
  font-size: 50rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.lottery-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lottery-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.lottery-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.lottery-arrow {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

/* 温馨提示卡片 */
.tips-card {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.2);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-align: center;
}

.tips-content {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.8;
  text-align: center;
  opacity: 0.95;
}
