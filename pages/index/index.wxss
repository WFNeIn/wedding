/* 首页样式 */
.index-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f8ff 0%, #ffffff 100%);
  padding-bottom: 40rpx;
  position: relative;
}

/* 自定义导航栏 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: transparent;
  z-index: 99999;
  transition: all 0.3s ease;
}

.custom-navbar.theme1 {
  background: linear-gradient(180deg, rgba(199, 107, 152, 0.95) 0%, rgba(199, 107, 152, 0) 100%);
}

.custom-navbar.theme2 {
  background: linear-gradient(180deg, rgba(27, 122, 94, 0.95) 0%, rgba(27, 122, 94, 0) 100%);
}

.custom-navbar.theme3 {
  background: linear-gradient(180deg, rgba(46, 80, 144, 0.95) 0%, rgba(46, 80, 144, 0) 100%);
}

.custom-navbar.theme4 {
  background: linear-gradient(180deg, rgba(220, 20, 60, 0.95) 0%, rgba(220, 20, 60, 0) 100%);
}

.custom-navbar.theme5 {
  background: linear-gradient(180deg, rgba(255, 182, 193, 0.95) 0%, rgba(255, 182, 193, 0) 100%);
}

.navbar-content {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
}

/* 首页内容初始隐藏 */
.index-container > view:not(.opening-animation):not(.theme-switch-btn):not(.theme-selector-modal) {
  opacity: 0;
}

/* 开场动画遮罩 */
.opening-animation {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: linear-gradient(135deg, #8B0000 0%, #B22222 30%, #DC143C 60%, #C41E3A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 移除自动消失的动画 */
}

/* 添加背景装饰 */
.opening-animation::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 30%, rgba(255, 215, 0, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(255, 215, 0, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
  pointer-events: none;
}

/* 添加中式云纹装饰 */
.opening-animation::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle, rgba(255, 215, 0, 0.1) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  opacity: 0.3;
  pointer-events: none;
}

/* 请柬信封容器 */
.invitation-envelope {
  width: 650rpx;
  height: 420rpx;
  position: relative;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.invitation-envelope:active {
  transform: scale(0.98);
}

/* 信封主体 */
.envelope-body {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #fffef9 0%, #fefcf3 100%);
  border-radius: 32rpx;
  box-shadow: 
    0 40rpx 100rpx rgba(0, 0, 0, 0.4),
    0 20rpx 50rpx rgba(139, 0, 0, 0.3),
    inset 0 0 100rpx rgba(212, 175, 55, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  border: 3rpx solid rgba(212, 175, 55, 0.3);
}

.invitation-envelope.opening .envelope-body {
  transform: scale(0.95);
  opacity: 0.3;
}

/* 信封三角翻盖 */
.envelope-flap {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 0;
  z-index: 5;
  pointer-events: none;
  transition: all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.flap-triangle {
  width: 0;
  height: 0;
  border-left: 325rpx solid transparent;
  border-right: 325rpx solid transparent;
  border-top: 180rpx solid #e8d4b8;
  position: absolute;
  top: 0;
  left: 0;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.3));
  transition: all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* 翻盖打开状态 */
.envelope-flap.open .flap-triangle {
  transform: translateY(-180rpx) rotateX(180deg);
  opacity: 0;
}

/* 信封内容区域 */
.envelope-content {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 80rpx 50rpx;
  position: relative;
  z-index: 2;
}

/* 顶部装饰线 */
.envelope-decoration-top {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 20rpx;
}

.decoration-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, rgba(212, 175, 55, 0.5), transparent);
}

.decoration-pattern {
  font-size: 24rpx;
  color: rgba(212, 175, 55, 0.8);
}

/* 中央主要内容 */
.envelope-main-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 24rpx;
}

/* 婚礼标题 */
.envelope-title {
  text-align: center;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #8B4513;
  letter-spacing: 8rpx;
  font-family: "KaiTi", "STKaiti", serif;
  opacity: 0.85;
}

/* 新人名字 */
.envelope-couple {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.couple-name-large {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 8rpx;
  font-family: "KaiTi", "STKaiti", serif;
  filter: drop-shadow(0 2rpx 8rpx rgba(212, 175, 55, 0.4));
}

.couple-separator-large {
  font-size: 36rpx;
  font-weight: 300;
  color: #d4af37;
  opacity: 0.8;
}

/* 日期信息 */
.envelope-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.date-label {
  font-size: 22rpx;
  color: #A0522D;
  letter-spacing: 2rpx;
  font-family: "KaiTi", "STKaiti", serif;
  opacity: 0.8;
}

.date-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #8B4513;
  letter-spacing: 2rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

/* 底部装饰线 */
.envelope-decoration-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 20rpx;
}

/* 移除旧样式 */
.envelope-texture,
.envelope-border-decoration,
.envelope-fold-lines,
.fold-line,
.envelope-stamp,
.stamp-inner,
.stamp-text,
.envelope-address-area,
.address-line,
.address-label,
.address-text,
.envelope-names,
.name-text,
.date-text {
  display: none;
}

/* 印章封条容器（在三角翻盖上） */
.seal-wrapper {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 6;
  transition: all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.seal-wrapper.broken {
  animation: sealBreak 0.8s ease forwards;
}

@keyframes sealBreak {
  0% {
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
    opacity: 1;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.2) rotate(10deg);
    opacity: 0.8;
  }
  100% {
    transform: translate(-50%, -200%) scale(0.3) rotate(45deg);
    opacity: 0;
  }
}

/* 中式印章 */
/* 中式印章 */
.seal-stamp {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  animation: sealFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 16rpx rgba(212, 175, 55, 0.6));
}

@keyframes sealFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-10rpx) rotate(2deg);
  }
}

.seal-border {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    inset 0 0 0 6rpx rgba(139, 0, 0, 0.2),
    inset 0 0 0 12rpx #d4af37,
    inset 0 4rpx 10rpx rgba(0, 0, 0, 0.15),
    0 0 30rpx rgba(212, 175, 55, 0.8);
  position: relative;
  opacity: 0.98;
}

.seal-border::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 88%;
  height: 88%;
  border: 2rpx solid rgba(139, 0, 0, 0.3);
  border-radius: 50%;
}

.seal-border::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.4) 0%, transparent 60%);
}

.seal-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8B0000;
  font-family: "KaiTi", "STKaiti", "PingFang SC", serif;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 1;
}

.seal-text-top {
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 6rpx;
}

.seal-text-bottom {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
}

/* 点击提示 */
.click-hint {
  position: absolute;
  bottom: -140rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  animation: bounce 1.5s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-20rpx);
  }
}

.hint-text {
  font-size: 32rpx;
  color: #FFD700;
  font-weight: 600;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.6);
  letter-spacing: 6rpx;
  font-family: "KaiTi", "STKaiti", "PingFang SC", serif;
}

.hint-icon {
  font-size: 48rpx;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.2);
  }
}

/* 信件内容 */
.letter-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  pointer-events: none;
  transition: all 0.8s ease;
}

.letter-content.show {
  opacity: 1;
  animation: letterUnfold 0.8s ease forwards;
}

@keyframes letterUnfold {
  0% {
    transform: translate(-50%, -50%) scale(0.5) rotateX(90deg);
    opacity: 0;
  }
  100% {
    transform: translate(-50%, -50%) scale(1) rotateX(0deg);
    opacity: 1;
  }
}

.letter-paper {
  width: 600rpx;
  background: linear-gradient(135deg, #fffef9 0%, #fefcf3 100%);
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  box-shadow: 
    0 30rpx 80rpx rgba(139, 69, 19, 0.2),
    0 0 0 2rpx rgba(139, 69, 19, 0.1);
  position: relative;
}

.letter-paper::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.1);
  border-radius: 16rpx;
  pointer-events: none;
}

.letter-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.letter-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #8B4513;
  letter-spacing: 12rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.letter-divider {
  width: 200rpx;
  height: 4rpx;
  background: linear-gradient(to right, transparent, #DC143C, transparent);
  margin: 30rpx auto 0;
}

.letter-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.letter-greeting {
  font-size: 40rpx;
  color: #8B4513;
  font-weight: 600;
  margin-bottom: 20rpx;
  letter-spacing: 6rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.letter-message {
  font-size: 28rpx;
  color: #A0522D;
  margin-bottom: 40rpx;
  letter-spacing: 4rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.letter-couple {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.couple-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #DC143C;
  letter-spacing: 4rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.couple-separator {
  font-size: 36rpx;
  color: #DC143C;
  margin: 0 20rpx;
  font-weight: 300;
}

.letter-date {
  font-size: 26rpx;
  color: #A0522D;
  letter-spacing: 2rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.letter-footer {
  text-align: center;
}

.footer-seal {
  font-size: 60rpx;
  opacity: 0.8;
}

/* 移除旧样式 */
.fade-in-page {
  animation: pageSlideIn 1s ease forwards !important;
}

@keyframes pageSlideIn {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 为不同元素添加延迟,创造层次感 */
.swiper-container.fade-in-page {
  animation-delay: 0s;
}

.info-card.fade-in-page {
  animation-delay: 0.2s;
}

.lottery-card.fade-in-page {
  animation-delay: 0.4s;
}

.tips-card.fade-in-page {
  animation-delay: 0.6s;
}

/* 轮播图容器 */
.swiper-container {
  width: 100%;
  height: 750rpx;
  position: relative;
  overflow: hidden;
}

.photo-swiper {
  width: 100%;
  height: 100%;
}

.photo-image {
  width: 100%;
  height: 100%;
}

/* 婚礼信息卡片 */
.info-card {
  margin: -80rpx 30rpx 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(135, 206, 235, 0.15);
