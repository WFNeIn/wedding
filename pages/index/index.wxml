<!-- 首页 - 邀请函 -->
<view class="index-container">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar {{currentTheme}}">
    <view class="navbar-content">
      <text class="navbar-title">峰琴喜事</text>
    </view>
  </view>

  <!-- 主题切换按钮（始终显示） -->
  <view class="theme-switch-btn" catchtap="toggleThemeSelector">
    <text class="theme-icon">🎨</text>
  </view>

  <!-- 开场动画遮罩 -->
  <view class="opening-animation {{currentTheme}}" wx:if="{{showOpening}}">
    <!-- 请柬信封 -->
    <view class="invitation-envelope {{openingStep >= 1 ? 'opening' : ''}}" bindtap="onClickInvitation">
      <!-- 信封主体 -->
      <view class="envelope-body">
        <!-- 信封三角翻盖 -->
        <view class="envelope-flap {{openingStep >= 1 ? 'open' : ''}}">
          <view class="flap-triangle"></view>
        </view>
        
        <!-- 信封内容区域 -->
        <view class="envelope-content">
          <!-- 空白信封，只显示印章 -->
        </view>
        
        <!-- 印章封条 -->
        <view class="seal-wrapper {{openingStep >= 1 ? 'broken' : ''}}">
          <view class="seal-stamp">
            <view class="seal-border">
              <!-- 装饰花纹 -->
              <view class="seal-decoration">
                <!-- 马的图案 -->
                <view class="horse-pattern">
                  <text class="horse-emoji">🐴</text>
                </view>
                <!-- 装饰星光 -->
                <text class="decoration-sparkle decoration-1">✦</text>
                <text class="decoration-sparkle decoration-2">✦</text>
                <text class="decoration-sparkle decoration-3">✧</text>
                <text class="decoration-sparkle decoration-4">✧</text>
              </view>
              <!-- 内容 -->
              <view class="seal-content">
                <text class="seal-divider-top">———</text>
                <text class="seal-text-top">W & Y</text>
                <text class="seal-text-bottom">WEDDING</text>
                <text class="seal-divider-bottom">———</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 信件内容 -->
      <view class="letter-content {{openingStep >= 2 ? 'show' : ''}}">
        <view class="letter-paper">
          <view class="letter-header">
            <text class="letter-title">婚礼邀请函</text>
            <view class="letter-divider"></view>
          </view>
          <view class="letter-body">
            <text class="letter-greeting">诚挚邀请您</text>
            <text class="letter-message">共同见证我们的幸福时刻</text>
            <view class="letter-couple">
              <text class="couple-name">{{groomName}}</text>
              <text class="couple-separator">&</text>
              <text class="couple-name">{{brideName}}</text>
            </view>
            <text class="letter-date">{{weddingDateDisplay}}</text>
          </view>
          <view class="letter-footer">
            <view class="footer-seal">💒</view>
          </view>
        </view>
      </view>
      
      <!-- 点击提示 -->
      <view class="click-hint" wx:if="{{openingStep === 0}}">
        <text class="hint-text">点击拆封</text>
        <view class="hint-icon">👆</view>
      </view>
    </view>
  </view>

  <!-- 轮播图 - 婚纱照 -->
  <view class="swiper-container {{showOpening ? '' : 'fade-in-page'}}">
    <swiper 
      class="photo-swiper" 
      indicator-dots="{{true}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="#87CEEB"
      autoplay="{{true}}"
      interval="{{3000}}"
      duration="{{500}}"
      circular="{{true}}"
    >
      <swiper-item wx:for="{{photos}}" wx:key="index">
        <image 
          src="{{item}}" 
          mode="aspectFill" 
          class="photo-image"
          binderror="onImageError"
        />
      </swiper-item>
    </swiper>
  </view>

  <!-- 婚礼信息卡片 -->
  <view class="info-card card {{showOpening ? '' : 'fade-in-page'}}">
    <!-- 新人名字 -->
    <view class="couple-names">
      <text class="name">{{groomName}}</text>
      <text class="separator">&</text>
      <text class="name">{{brideName}}</text>
    </view>

    <!-- 分隔线 -->
    <view class="divider"></view>

    <!-- 婚礼日期 -->
    <view class="info-detail-card" bindtap="openMojiWeather">
      <view class="detail-icon-box date-icon">
        <text class="detail-icon">📆</text>
      </view>
      <view class="detail-content">
        <text class="detail-label">婚礼日期</text>
        <text class="detail-value">{{weddingDateDisplay}}</text>
        <text class="detail-hint">点击查看当日天气</text>
      </view>
      <view class="detail-arrow">
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 婚宴地点 -->
    <view class="info-detail-card" bindtap="goToDetails">
      <view class="detail-icon-box venue-icon">
        <text class="detail-icon">💒</text>
      </view>
      <view class="detail-content">
        <text class="detail-label">婚宴地点</text>
        <text class="detail-value">{{venue}}</text>
        <text class="detail-address">{{address}}</text>
      </view>
      <view class="detail-arrow">
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 倒计时 -->
    <view class="countdown-container">
      <view class="countdown-box">
        <!-- 婚礼前 -->
        <block wx:if="{{countdownStatus === 'before'}}">
          <text class="countdown-label">距离婚礼还有</text>
          <view class="countdown-time-box">
            <view class="time-item">
              <text class="time-number">{{countdown.days}}</text>
              <text class="time-unit">天</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.hours}}</text>
              <text class="time-unit">时</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.minutes}}</text>
              <text class="time-unit">分</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.seconds}}</text>
              <text class="time-unit">秒</text>
            </view>
          </view>
        </block>
        
        <!-- 婚礼当天 -->
        <block wx:elif="{{countdownStatus === 'today'}}">
          <text class="countdown-label">🎉 婚礼进行中！</text>
          <view class="countdown-time-box">
            <view class="time-item special">
              <text class="time-number">0</text>
              <text class="time-unit">天</text>
            </view>
            <view class="time-item special">
              <text class="time-number">0</text>
              <text class="time-unit">时</text>
            </view>
            <view class="time-item special">
              <text class="time-number">0</text>
              <text class="time-unit">分</text>
            </view>
            <view class="time-item special">
              <text class="time-number">0</text>
              <text class="time-unit">秒</text>
            </view>
          </view>
        </block>
        
        <!-- 婚礼后 -->
        <block wx:else>
          <text class="countdown-label">婚礼已举办</text>
          <view class="countdown-time-box">
            <view class="time-item">
              <text class="time-number">{{countdown.days}}</text>
              <text class="time-unit">天</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.hours}}</text>
              <text class="time-unit">时</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.minutes}}</text>
              <text class="time-unit">分</text>
            </view>
            <view class="time-item">
              <text class="time-number">{{countdown.seconds}}</text>
              <text class="time-unit">秒</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 抽奖入口 -->
  <view class="lottery-card card {{showOpening ? '' : 'fade-in-page'}}" bindtap="goToLottery">
    <view class="lottery-icon-box">
      <text class="lottery-icon">🎁</text>
    </view>
    <view class="lottery-content">
      <view class="lottery-title">幸运抽奖</view>
      <view class="lottery-desc">点击查看您的抽奖号码</view>
    </view>
    <view class="lottery-arrow">
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-card card {{showOpening ? '' : 'fade-in-page'}}">
    <view class="tips-title">💝 诚挚邀请</view>
    <view class="tips-content">
      我们诚挚地邀请您参加我们的婚礼，共同见证这一美好时刻。期待您的到来！
    </view>
  </view>

  <!-- 主题选择器弹窗（独立显示，不受showOpening影响） -->
  <view class="theme-selector-modal {{currentTheme}}" wx:if="{{showThemeSelector}}" catchtap="closeThemeSelector">
    <view class="theme-selector-content" catchtap="stopPropagation">
      <view class="theme-selector-title">选择主题配色</view>
      
      <view class="theme-options">
        <!-- 方案1：玫瑰金 + 香槟色 -->
        <view class="theme-option {{currentTheme === 'theme1' ? 'active' : ''}}" 
              data-theme="theme1" 
              bindtap="switchTheme">
          <view class="theme-preview theme1-preview">
            <view class="preview-bg"></view>
            <view class="preview-seal"></view>
          </view>
          <text class="theme-name">玫瑰金</text>
          <text class="theme-desc">浪漫优雅</text>
        </view>

        <!-- 方案2：翡翠绿 + 金色 -->
        <view class="theme-option {{currentTheme === 'theme2' ? 'active' : ''}}" 
              data-theme="theme2" 
              bindtap="switchTheme">
          <view class="theme-preview theme2-preview">
            <view class="preview-bg"></view>
            <view class="preview-seal"></view>
          </view>
          <text class="theme-name">翡翠绿</text>
          <text class="theme-desc">清新高级</text>
        </view>

        <!-- 方案3：宝石蓝 + 银色 -->
        <view class="theme-option {{currentTheme === 'theme3' ? 'active' : ''}}" 
              data-theme="theme3" 
              bindtap="switchTheme">
          <view class="theme-preview theme3-preview">
            <view class="preview-bg"></view>
            <view class="preview-seal"></view>
          </view>
          <text class="theme-name">宝石蓝</text>
          <text class="theme-desc">典雅大气</text>
        </view>

        <!-- 方案4：中国红 + 金色 -->
        <view class="theme-option {{currentTheme === 'theme4' ? 'active' : ''}}" 
              data-theme="theme4" 
              bindtap="switchTheme">
          <view class="theme-preview theme4-preview">
            <view class="preview-bg"></view>
            <view class="preview-seal"></view>
          </view>
          <text class="theme-name">中国红</text>
          <text class="theme-desc">传统喜庆</text>
        </view>

        <!-- 方案5：樱花粉 + 金色 -->
        <view class="theme-option {{currentTheme === 'theme5' ? 'active' : ''}}" 
              data-theme="theme5" 
              bindtap="switchTheme">
          <view class="theme-preview theme5-preview">
            <view class="preview-bg"></view>
            <view class="preview-seal"></view>
          </view>
          <text class="theme-name">樱花粉</text>
          <text class="theme-desc">甜美梦幻</text>
        </view>
      </view>
    </view>
  </view>
</view>
